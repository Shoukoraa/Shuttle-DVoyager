{
	"info": {
		"_postman_id": "c1f7a3a9-1b3a-4e78-9e56-11f87a8b419c",
		"name": "Shuttle System API",
		"description": "API Collection for Shuttle Booking System (bisa diimport ke Apidog atau Postman)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Public & Auth",
			"item": [
				{
					"name": "Login",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Accept", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"customer1@shuttle.com\",\n    \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/auth/login",
							"host": [ "{{base_url}}" ],
							"path": [ "api", "auth", "login" ]
						}
					}
				},
				{
					"name": "Cari Jadwal (Schedules)",
					"request": {
						"method": "GET",
						"header": [ { "key": "Accept", "value": "application/json" } ],
						"url": {
							"raw": "{{base_url}}/api/schedules",
							"host": [ "{{base_url}}" ],
							"path": [ "api", "schedules" ]
						}
					}
				}
			]
		},
		{
			"name": "2. Customer (Butuh Token)",
			"item": [
				{
					"name": "My Bookings",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": {
							"raw": "{{base_url}}/api/customer/my-bookings",
							"host": [ "{{base_url}}" ],
							"path": [ "api", "customer", "my-bookings" ]
						}
					}
				},
				{
					"name": "Create Booking",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"schedule_id\": 1,\n    \"seats\": [\"1\", \"2\"]\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/customer/booking",
							"host": [ "{{base_url}}" ],
							"path": [ "api", "customer", "booking" ]
						}
					}
				}
			]
		},
		{
			"name": "3. Driver (Butuh Token)",
			"item": [
				{
					"name": "My Schedules",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": {
							"raw": "{{base_url}}/api/driver/my-schedules",
							"host": [ "{{base_url}}" ],
							"path": [ "api", "driver", "my-schedules" ]
						}
					}
				},
				{
					"name": "Start Schedule (Mulai Jalan)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": {
							"raw": "{{base_url}}/api/driver/schedule/1/start",
							"host": [ "{{base_url}}" ],
							"path": [ "api", "driver", "schedule", "1", "start" ]
						}
					}
				}
			]
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost/D-Voyager-BackEnd/public",
			"type": "string"
		},
		{
			"key": "token",
			"value": "ISI_TOKEN_DISINI",
			"type": "string"
		}
	]
}
